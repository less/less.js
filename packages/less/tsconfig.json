{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "node",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "esModuleInterop": true,
    "noImplicitAny": true,
    "strict": false,
    "skipLibCheck": true,
    "rootDir": "."
  },
  "include": ["lib/**/*"],
  "exclude": ["node_modules"]
}
